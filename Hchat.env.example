# ============================================
# Terminal Care - Environment Configuration
# ============================================

# Gemini API Key (用于默认的 Gemini 模型)
# 如果没有设置，会使用自定义 API
GEMINI_API_KEY=your_gemini_api_key_here

# 自定义 API 配置（可选，留空则使用 Gemini）
# 支持 OpenAI 兼容格式的 API，如 OpenRouter、SiliconFlow 等
# VITE_API_URL=http://localhost:3001/api
# VITE_CUSTOM_API_KEY=your_api_key_here
# VITE_CUSTOM_MODEL=gpt-4o

# 后端端口
PORT=3001
